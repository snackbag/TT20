{
  "required": true,
  "minVersion": "0.8",
  "package": "net.snackbag.tt20.mixin",
  "compatibilityLevel": "${java_compatibility_level}",
  "plugin": "net.snackbag.tt20.mixin.TT20MixinPlugin",
  "mixins": [
    "ServerWatchdogMixin",
    "LivingEntityMixin",
    "MinecraftServerMixin",
    "PlayerMixin",
    "PortalProcessorMixin",
    "accessor.ServerPlayerAccessor",
    "ServerPlayerManagerMixin",
    "fluid.LavaFluidMixin",
    "fluid.WaterFluidMixin",
    "item.ItemEntityMixin",
    "item.ItemMixin",
    "world.BlockBehaviourMixin",
    "world.GameRulesMixin",
    "world.ServerLevelMixin",
    "world.LevelChunkMixin"
  ],
  "client": [
    "client.ChatComponentMixin",
    "client.IntegratedServerMixin"
  ],
  "injectors": {
    "defaultRequire": 1
  }
}